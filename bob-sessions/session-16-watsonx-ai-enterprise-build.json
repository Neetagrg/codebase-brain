    <script>
        // ROI Calculator
        const teamSizeInput = document.getElementById('teamSize');
        const salaryInput = document.getElementById('salary');
        const teamSizeDisplay = document.getElementById('teamSizeDisplay');
        const salaryDisplay = document.getElementById('salaryDisplay');
        const timeSaved = document.getElementById('timeSaved');
        const costSavings = document.getElementById('costSavings');
        const roiPercent = document.getElementById('roiPercent');

        function calculateROI() {
            const teamSize = parseInt(teamSizeInput.value);
            const salary = parseInt(salaryInput.value);
            
            // Update displays
            teamSizeDisplay.textContent = `${teamSize} developers`;
            salaryDisplay.textContent = `$${salary.toLocaleString()}/year`;
            
            // Calculate savings (30 min/day per developer = 130 hours/year)
            const hoursPerYear = 130;
            const totalHours = teamSize * hoursPerYear;
            const hourlyRate = salary / 2080; // 2080 work hours per year
            const savings = totalHours * hourlyRate;
            
            // Annual cost of Codebase Brain (assuming $99/user/month)
            const annualCost = teamSize * 99 * 12;
            const roi = ((savings - annualCost) / annualCost * 100).toFixed(0);
            
            timeSaved.textContent = `${totalHours.toLocaleString()} hours`;
            costSavings.textContent = `$${Math.round(savings).toLocaleString()}`;
            roiPercent.textContent = `${roi.toLocaleString()}%`;
        }

        teamSizeInput.addEventListener('input', calculateROI);
        salaryInput.addEventListener('input', calculateROI);
        
        // Initialize
        calculateROI();

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
