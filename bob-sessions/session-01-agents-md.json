<file><path>scripts/validate_inertia.py</path>
<content lines="1-228">
  1 | """
  2 | calculate_com.py  —  Joint-transform-aware CoM validator for ArduPilot SITL URDF
  3 | Fixes vs original:
  4 |   - Builds a joint transform tree and accumulates each link's inertial origin
  5 |     in world frame before summing, so the reported CoM is physically correct.
  6 |   - Validates inertia triangle inequality per link.
  7 |   - Reports total mass, world-frame CoM, and lateral symmetry check.
  8 |   - Warns if any inertia diagonal entry is below the ODE stability floor (1e-4).
  9 | """
 10 | 
 11 | import xml.etree.ElementTree as ET
 12 | import os
 13 | import numpy as np
 14 | 
 15 | 
 16 | # ─────────────────────────────────────────────
 17 | # Helpers
 18 | # ─────────────────────────────────────────────
 19 | 
 20 | def parse_xyz(element, attr="xyz"):
 21 |     """Return np.array([x, y, z]) from an XML element attribute, defaulting to zeros."""
 22 |     if element is None:
 23 |         return np.zeros(3)
 24 |     raw = element.get(attr, "0 0 0").split()
 25 |     return np.array([float(v) for v in raw])
 26 | 
 27 | 
 28 | def parse_rpy(element):
 29 |     """Return (roll, pitch, yaw) from an XML element's 'rpy' attribute."""
 30 |     if element is None:
 31 |         return 0.0, 0.0, 0.0
 32 |     raw = element.get("rpy", "0 0 0").split()
 33 |     return tuple(float(v) for v in raw)
 34 | 
 35 | 
 36 | def rpy_to_matrix(roll, pitch, yaw):
 37 |     """
 38 |     Build a 3×3 rotation matrix from roll-pitch-yaw (extrinsic XYZ convention,
 39 |     same as URDF/ROS).
 40 |     """
 41 |     cr, sr = np.cos(roll),  np.sin(roll)
 42 |     cp, sp = np.cos(pitch), np.sin(pitch)
 43 |     cy, sy = np.cos(yaw),   np.sin(yaw)
 44 | 
 45 |     Rx = np.array([[1,  0,   0 ],
 46 |                    [0,  cr, -sr],
 47 |                    [0,  sr,  cr]])
 48 |     Ry = np.array([[ cp, 0, sp],
 49 |                    [  0, 1,  0],
 50 |                    [-sp, 0, cp]])
 51 |     Rz = np.array([[cy, -sy, 0],
 52 |                    [sy,  cy, 0],
 53 |                    [ 0,   0, 1]])
 54 |     return Rz @ Ry @ Rx
 55 | 
 56 | 
 57 | def make_transform(origin_element):
 58 |     """
 59 |     Return (R, t): 3×3 rotation matrix and 3-vector translation
 60 |     from a URDF <origin xyz="..." rpy="..."/> element (or None → identity).
 61 |     """
 62 |     t = parse_xyz(origin_element)
 63 |     r, p, y = parse_rpy(origin_element)
 64 |     R = rpy_to_matrix(r, p, y)
 65 |     return R, t
 66 | 
 67 | 
 68 | # ─────────────────────────────────────────────
 69 | # Build kinematic tree from URDF
 70 | # ─────────────────────────────────────────────
 71 | 
 72 | def build_tree(root):
 73 |     """
 74 |     Returns:
 75 |         link_inertials : dict  link_name → (mass, local_com_xyz, inertia_dict)
 76 |         joint_map      : dict  child_link_name → (parent_link_name, R_joint, t_joint)
 77 |     """
 78 |     link_inertials = {}
 79 |     for link in root.findall("link"):
 80 |         name = link.get("name")
 81 |         inertial = link.find("inertial")
 82 |         if inertial is None:
 83 |             link_inertials[name] = (0.0, np.zeros(3), None)
 84 |             continue
 85 | 
 86 |         mass_elem = inertial.find("mass")
 87 |         mass = float(mass_elem.get("value", 0)) if mass_elem is not None else 0.0
 88 | 
 89 |         origin = inertial.find("origin")
 90 |         local_com = parse_xyz(origin)
 91 | 
 92 |         inertia_elem = inertial.find("inertia")
 93 |         inertia = {}
 94 |         if inertia_elem is not None:
 95 |             for attr in ("ixx", "ixy", "ixz", "iyy", "iyz", "izz"):
 96 |                 inertia[attr] = float(inertia_elem.get(attr, 0))
 97 | 
 98 |         link_inertials[name] = (mass, local_com, inertia)
 99 | 
100 |     joint_map = {}   # child → (parent, R, t)
101 |     for joint in root.findall("joint"):
102 |         parent = joint.find("parent").get("link")
103 |         child  = joint.find("child").get("link")
104 |         origin = joint.find("origin")
105 |         R, t   = make_transform(origin)
106 |         joint_map[child] = (parent, R, t)
107 | 
108 |     return link_inertials, joint_map
109 | 
110 | 
111 | def world_transform(link_name, joint_map):
112 |     """
113 |     Walk up the kinematic chain to compute the world-frame transform
114 |     (R_world, t_world) for link_name's origin.
115 |     Returns (R, t) where t is the position of the link's frame origin in world.
116 |     """
117 |     R = np.eye(3)
118 |     t = np.zeros(3)
119 |     current = link_name
120 | 
121 |     chain = []
122 |     while current in joint_map:
123 |         parent, R_j, t_j = joint_map[current]
124 |         chain.append((R_j, t_j))
125 |         current = parent
126 | 
127 |     # Apply transforms from root → leaf
128 |     for R_j, t_j in reversed(chain):
129 |         t = t + R @ t_j
130 |         R = R @ R_j
131 | 
132 |     return R, t
133 | 
134 | 
135 | # ─────────────────────────────────────────────
136 | # Inertia validation
137 | # ─────────────────────────────────────────────
138 | 
139 | ODE_INERTIA_FLOOR = 1e-4   # kg·m² — below this ODE becomes numerically rank-deficient
140 | 
141 | def check_inertia(link_name, inertia):
142 |     """Print triangle-inequality and ODE floor warnings for a single link."""
143 |     if not inertia:
144 |         return
145 |     ixx = inertia.get("ixx", 0)
146 |     iyy = inertia.get("iyy", 0)
147 |     izz = inertia.get("izz", 0)
148 | 
149 |     issues = []
150 |     if ixx + iyy < izz - 1e-9: issues.append("ixx+iyy < izz  (triangle inequality violated)")
151 |     if ixx + izz < iyy - 1e-9: issues.append("ixx+izz < iyy  (triangle inequality violated)")
152 |     if iyy + izz < ixx - 1e-9: issues.append("iyy+izz < ixx  (triangle inequality violated)")
153 | 
154 |     for v, label in ((ixx, "ixx"), (iyy, "iyy"), (izz, "izz")):
155 |         if 0 < v < ODE_INERTIA_FLOOR:
156 |             issues.append(f"{label}={v:.2e} is below ODE stability floor {ODE_INERTIA_FLOOR:.0e}")
157 | 
158 |     for issue in issues:
159 |         print(f"  ⚠️  {link_name}: {issue}")
160 | 
161 | 
162 | # ─────────────────────────────────────────────
163 | # Main analysis
164 | # ─────────────────────────────────────────────
165 | 
166 | def calculate_com(urdf_file):
167 |     tree = ET.parse(urdf_file)
168 |     root = tree.getroot()
169 | 
170 |     link_inertials, joint_map = build_tree(root)
171 | 
172 |     total_mass = 0.0
173 |     world_com  = np.zeros(3)
174 | 
175 |     print(f"\n{'─'*62}")
176 |     print(f"  CoM Analysis (world frame): {os.path.basename(urdf_file)}")
177 |     print(f"{'─'*62}")
178 |     print(f"  {'Link':<22} {'Mass':>6}  {'World CoM (x, y, z)'}")
179 |     print(f"{'─'*62}")
180 | 
181 |     for link_name, (mass, local_com, inertia) in link_inertials.items():
182 |         if mass <= 0:
183 |             continue
184 | 
185 |         # Get world-frame transform of this link's origin
186 |         R_w, t_w = world_transform(link_name, joint_map)
187 | 
188 |         # CoM in world frame = link_origin_world + R_world · local_com
189 |         com_world = t_w + R_w @ local_com
190 | 
191 |         print(f"  {link_name:<22} {mass:>5.3f}kg  "
192 |               f"({com_world[0]:+.4f}, {com_world[1]:+.4f}, {com_world[2]:+.4f})")
193 | 
194 |         check_inertia(link_name, inertia)
195 | 
196 |         total_mass   += mass
197 |         world_com    += mass * com_world
198 | 
199 |     if total_mass > 0:
200 |         world_com /= total_mass
201 | 
202 |     print(f"{'─'*62}")
203 |     print(f"  TOTAL MASS : {total_mass:.4f} kg")
204 |     print(f"  WORLD CoM  : X={world_com[0]:+.4f}  Y={world_com[1]:+.4f}  Z={world_com[2]:+.4f}")
205 |     print(f"{'─'*62}")
206 | 
207 |     # Symmetry checks
208 |     if abs(world_com[1]) > 0.001:
209 |         print(f"  ⚠️  LATERAL CoM (Y) = {world_com[1]:.4f} m — robot is NOT laterally centred!")
210 |     else:
