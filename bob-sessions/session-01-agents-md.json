 1 | import xml.etree.ElementTree as ET
 2 | import os
 3 | 
 4 | def calculate_com(urdf_file):
 5 |     tree = ET.parse(urdf_file)
 6 |     root = tree.getroot()
 7 |     
 8 |     total_mass = 0.0
 9 |     weighted_x, weighted_y, weighted_z = 0.0, 0.0, 0.0
10 | 
11 |     print(f"--- Center of Mass Analysis: {os.path.basename(urdf_file)} ---")
12 | 
13 |     for link in root.findall('link'):
14 |         inertial = link.find('inertial')
15 |         if inertial is not None:
16 |             mass_elem = inertial.find('mass')
17 |             if mass_elem is None: continue
18 |             
19 |             mass = float(mass_elem.get('value', 0))
20 |             origin = inertial.find('origin')
21 |             
22 |             # If origin is missing, default to 0 0 0
23 |             if origin is not None:
24 |                 xyz = origin.get('xyz', '0 0 0').split()
25 |             else:
26 |                 xyz = ['0', '0', '0']
27 |                 
28 |             x, y, z = map(float, xyz)
29 | 
30 |             total_mass += mass
31 |             weighted_x += mass * x
32 |             weighted_y += mass * y
33 |             weighted_z += mass * z
34 |             print(f"Link: {link.get('name'):<20} | Mass: {mass:<5}kg")
35 | 
36 |     if total_mass > 0:
37 |         com_x = weighted_x / total_mass
38 |         com_y = weighted_y / total_mass
39 |         com_z = weighted_z / total_mass
40 | 
41 |         print("-" * 50)
42 |         print(f"TOTAL ROBOT MASS: {total_mass:.3f} kg")
43 |         print(f"AGGREGATE CoM:    X: {com_x:.3f}, Y: {com_y:.3f}, Z: {com_z:.3f}")
44 |         print("-" * 50)
45 |         
46 |         if abs(com_y) > 0.01:
47 |             print("⚠️ WARNING: Lateral CoM (Y) is not centered!")
48 |         else:
49 |             print("✅ Lateral Symmetry Verified (Y-axis is centered).")
50 | 
51 | if __name__ == "__main__":
52 |     script_dir = os.path.dirname(os.path.abspath(__file__))
53 |     urdf_path = os.path.join(script_dir, '..', 'humanoid_proto.urdf')
54 |     calculate_com(urdf_path)
