<content lines="1-125">
  1 | #!/usr/bin/env python3
  2 | import time, math, subprocess
  3 | from pymavlink import mavutil
  4 | 
  5 | MAVLINK_URL = 'udp:127.0.0.1:14551'
  6 | HIP_STAND  = -0.09
  7 | KNEE_STAND =  0.35
  8 | KNEE_LIFT  =  0.55
  9 | HIP_STEP   =  0.05
 10 | DURATION   =  3.0
 11 | 
 12 | Kp, Ki, Kd = 0.08, 0.001, 0.01
 13 | integral, last_error, last_time = 0, 0, time.time()
 14 | 
 15 | def send(topic, val):
 16 |     subprocess.Popen(['gz','topic','-t',topic,'-m','gz.msgs.Double',
 17 |                      '-p',f'data: {val:.4f}'],
 18 |                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
 19 | 
 20 | def send_pose(lh, rh, lk, rk):
 21 |     send('/l_hip_pitch/cmd', lh)
 22 |     send('/r_hip_pitch/cmd', rh)
 23 |     send('/l_knee/cmd', lk)
 24 |     send('/r_knee/cmd', rk)
 25 |     send('/l_ankle/cmd', 0.0)
 26 |     send('/r_ankle/cmd', 0.0)
 27 | 
 28 | def balance(pitch, dt):
 29 |     global integral, last_error, last_time
 30 |     error = pitch
 31 |     integral = max(-0.3, min(0.3, integral + error * dt))
 32 |     derivative = (error - last_error) / dt
 33 |     last_error = error
 34 |     return max(-0.3, min(0.3, Kp*error + Ki*integral + Kd*derivative))
 35 | 
 36 | # Hold pose BEFORE connecting to MAVLink
 37 | print("Pre-holding pose before MAVLink connection...")
 38 | for _ in range(40):
 39 |     send('/l_hip_pitch/cmd', -0.09)
 40 |     send('/r_hip_pitch/cmd', -0.09)
 41 |     send('/l_knee/cmd', 0.35)
 42 |     send('/r_knee/cmd', 0.35)
 43 |     send('/l_ankle/cmd', 0.0)
 44 |     send('/r_ankle/cmd', 0.0)
 45 |     time.sleep(0.05)
 46 | print("Connecting to ArduPilot...")
 47 | mav = mavutil.mavlink_connection('udp:0.0.0.0:14551')
 48 | mav.wait_heartbeat()
 49 | print("Connected!")
 50 | 
 51 | # Kill startup.sh now that we're connected
 52 | subprocess.run(['pkill', '-f', 'startup.sh'], capture_output=True)
 53 | print("startup.sh stopped")
 54 | # Immediately hold standing pose to prevent fall
 55 | print("Holding pose...")
 56 | for _ in range(20):
 57 |     send_pose(HIP_STAND, HIP_STAND, KNEE_STAND, KNEE_STAND)
 58 |     time.sleep(0.05)
 59 | 
 60 | # Calibrate standing pitch
 61 | print("Calibrating...")
 62 | samples = []
 63 | for _ in range(20):
 64 |     msg = mav.recv_match(type='ATTITUDE', blocking=True, timeout=1.0)
 65 |     if msg:
 66 |         samples.append(msg.pitch)
 67 |     time.sleep(0.05)
 68 | STANDING_PITCH = sum(samples) / len(samples) if samples else 0.0
 69 | print(f"Standing pitch: {math.degrees(STANDING_PITCH):+.1f}°")
 70 | 
 71 | gait_phases = [
 72 |     (HIP_STAND,          HIP_STAND,          KNEE_STAND, KNEE_STAND, "STAND"),
 73 |     (HIP_STAND-0.05,     HIP_STAND+0.05,     KNEE_STAND, KNEE_STAND, "SHIFT_R"),
 74 |     (HIP_STAND+HIP_STEP, HIP_STAND,          KNEE_LIFT,  KNEE_STAND, "STEP_L"),
 75 |     (HIP_STAND,          HIP_STAND,          KNEE_STAND, KNEE_STAND, "STAND"),
 76 |     (HIP_STAND+0.05,     HIP_STAND-0.05,     KNEE_STAND, KNEE_STAND, "SHIFT_L"),
 77 |     (HIP_STAND,          HIP_STAND+HIP_STEP, KNEE_STAND, KNEE_LIFT,  "STEP_R"),
 78 | ]
 79 | 
 80 | print("Stabilizing 3 seconds...")
 81 | t_start = time.time()
 82 | while time.time() - t_start < 3.0:
 83 |     msg = mav.recv_match(type='ATTITUDE', blocking=True, timeout=0.5)
 84 |     if msg:
 85 |         now = time.time()
 86 |         dt = max(now - last_time, 0.01)
 87 |         bal = balance(msg.pitch - STANDING_PITCH, dt)
 88 |         last_time = now
 89 |         lh = HIP_STAND - bal
 90 |         rh = HIP_STAND - bal
 91 |         send_pose(lh, rh, KNEE_STAND, KNEE_STAND)
 92 |         print(f"\rSTABILIZE    | bal:{bal:+.3f} | LH:{lh:+.2f} RH:{rh:+.2f}", end='', flush=True)
 93 |     time.sleep(0.05)
 94 | 
 95 | print("\nGait starting!")
 96 | # Reset balance integral to prevent carry-over from stabilize phase
 97 | integral = 0
 98 | last_error = 0
 99 | phase = 0
100 | phase_start = time.time()
101 | 
102 | while True:
103 |     msg = mav.recv_match(type='ATTITUDE', blocking=True, timeout=0.5)
104 |     if not msg:
105 |         continue
106 | 
107 |     now = time.time()
108 |     dt = max(now - last_time, 0.01)
109 |     bal = balance(msg.pitch - STANDING_PITCH, dt)
110 |     last_time = now
111 | 
112 |     lh0, rh0, lk, rk, name = gait_phases[phase % len(gait_phases)]
113 |     elapsed = time.time() - phase_start
114 | 
115 |     if elapsed >= DURATION:
116 |         phase += 1
117 |         phase_start = time.time()
118 |         continue
119 | 
120 |     lh = lh0 - bal
121 |     rh = rh0 - bal
122 |     send_pose(lh, rh, lk, rk)
123 | 
124 |     print(f"\r{name:<12} | bal:{bal:+.3f} | LH:{lh:+.2f} RH:{rh:+.2f} LK:{lk:+.2f} RK:{rk:+.2f}", end='', flush=True)
125 |     time.sleep(0.05)
