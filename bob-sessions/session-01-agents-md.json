<file><path>scripts/inverse_kinematics.py</path>
<content lines="1-42">
 1 | import numpy as np
 2 | 
 3 | L1 = 0.20
 4 | L2 = 0.20
 5 | ANKLE_HEIGHT = 0.01
 6 | 
 7 | def leg_ik(foot_x, foot_z):
 8 |     r = np.sqrt(foot_x**2 + foot_z**2)
 9 |     r = np.clip(r, abs(L1-L2)+1e-4, L1+L2-1e-4)
10 |     cos_knee = (r**2 - L1**2 - L2**2) / (2*L1*L2)
11 |     cos_knee = np.clip(cos_knee, -1.0, 1.0)
12 |     knee = np.arccos(cos_knee)
13 |     alpha = np.arctan2(foot_x, -foot_z)
14 |     beta  = np.arccos(np.clip((r**2+L1**2-L2**2)/(2*r*L1), -1.0, 1.0))
15 |     hip_pitch = alpha - beta
16 |     hip_pitch = np.clip(hip_pitch, -1.57, 0.52)
17 |     knee      = np.clip(knee, 0.0, 2.618)
18 |     return hip_pitch, knee
19 | 
20 | def ankle_compensation(hip_pitch, knee):
21 |     ankle = -(hip_pitch + knee*0.3)
22 |     return np.clip(ankle, -0.5, 0.5)
23 | 
24 | class LegIKSolver:
25 |     HIP_Z_OFFSET = -0.09
26 | 
27 |     def __init__(self, side='left'):
28 |         self.side   = side
29 |         self.y_sign = 1.0 if side == 'left' else -1.0
30 | 
31 |     def solve(self, com_z, foot_x, foot_z_world, hip_roll=0.0):
32 |         # hip_pitch joint is at com_z height above ground
33 |         rel_x = foot_x
34 |         rel_z = foot_z_world - com_z
35 |         hip_pitch, knee = leg_ik(rel_x, rel_z)
36 |         ankle = ankle_compensation(hip_pitch, knee)
37 |         return {
38 |             'hip_roll':  float(np.clip(hip_roll, -0.4, 0.4)),
39 |             'hip_pitch': float(hip_pitch),
40 |             'knee':      float(knee),
41 |             'ankle':     float(ankle),
42 |         }
