  1 | #!/usr/bin/env python3
  2 | import time, math, subprocess, threading
  3 | import numpy as np
  4 | from pymavlink import mavutil
  5 | import sys
  6 | sys.path.insert(0, '/home/neetamis/humanoid-ardupilot-sitl/scripts')
  7 | from preview_control    import LIPMPreviewController, ZMPReferenceGenerator
  8 | from foot               import SwingFootTrajectory, FootstepPlanner
  9 | from inverse_kinematics import LegIKSolver
 10 | 
 11 | DT=0.02; COM_HEIGHT=0.38; PREVIEW_HORIZON=20
 12 | STEP_LENGTH=0.12; FOOT_SEP=0.08
 13 | STEP_DURATION=0.6; DS_DURATION=0.1
 14 | SWING_HEIGHT=0.08; N_STEPS=8
 15 | Kp_bal=0.10; Ki_bal=0.001; Kd_bal=0.01
 16 | 
 17 | pitch=0.0; roll=0.0; _lock=threading.Lock()
 18 | 
 19 | def mavlink_reader(mav):
 20 |     global pitch, roll
 21 |     while True:
 22 |         msg = mav.recv_match(type='ATTITUDE', blocking=True, timeout=1.0)
 23 |         if msg:
 24 |             with _lock:
 25 |                 pitch=msg.pitch; roll=msg.roll
 26 | 
 27 | def send_joint(topic, angle):
 28 |     subprocess.Popen(['gz','topic','-t',topic,'-m','gz.msgs.Double',
 29 |                       '-p',f'data: {angle:.4f}'],
 30 |                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
 31 | 
 32 | def send_all(lhr,lhp,lk,la,rhr,rhp,rk,ra):
 33 |     send_joint('/l_hip_roll/cmd',lhr)
 34 |     send_joint('/l_hip_pitch/cmd',lhp)
 35 |     send_joint('/l_knee/cmd',lk)
 36 |     send_joint('/l_ankle/cmd',la)
 37 |     send_joint('/r_hip_roll/cmd',rhr)
 38 |     send_joint('/r_hip_pitch/cmd',rhp)
 39 |     send_joint('/r_knee/cmd',rk)
 40 |     send_joint('/r_ankle/cmd',ra)
 41 | 
 42 | def main():
 43 |     print("ZMP Preview Gait Controller starting...")
 44 |     mav = mavutil.mavlink_connection('udp:0.0.0.0:14551')
 45 |     mav.wait_heartbeat()
 46 |     print("Connected!")
 47 |     subprocess.run(['pkill','-f','startup.sh'], capture_output=True)
 48 |     threading.Thread(target=mavlink_reader, args=(mav,), daemon=True).start()
 49 | 
 50 |     lipm_x = LIPMPreviewController(DT, COM_HEIGHT, PREVIEW_HORIZON)
 51 |     lipm_y = LIPMPreviewController(DT, COM_HEIGHT, PREVIEW_HORIZON)
 52 |     zmp_gen = ZMPReferenceGenerator(DT, STEP_DURATION, DS_DURATION,
 53 |                                     STEP_LENGTH, FOOT_SEP)
 54 |     planner = FootstepPlanner(STEP_LENGTH, FOOT_SEP, N_STEPS)
 55 |     ik_l = LegIKSolver('left')
 56 |     ik_r = LegIKSolver('right')
 57 | 
 58 |     zmp_x_ref, zmp_y_ref = zmp_gen.generate(N_STEPS)
 59 |     footsteps = planner.plan()
 60 |     total = len(zmp_x_ref)
 61 |     pad = PREVIEW_HORIZON
 62 |     zmp_x_pad = np.concatenate([zmp_x_ref, np.full(pad, zmp_x_ref[-1])])
 63 |     zmp_y_pad = np.concatenate([zmp_y_ref, np.full(pad, zmp_y_ref[-1])])
 64 | 
 65 |     bal_int=0.0; bal_last=0.0; last_t=time.time()
 66 | 
 67 |     j_l = ik_l.solve(COM_HEIGHT, 0.0, 0.0)
 68 |     j_r = ik_r.solve(COM_HEIGHT, 0.0, 0.0)
 69 |     print("Holding stand 3s...")
 70 |     t0=time.time()
 71 |     while time.time()-t0 < 3.0:
 72 |         send_all(j_l['hip_roll'],j_l['hip_pitch'],j_l['knee'],j_l['ankle'],
 73 |                  j_r['hip_roll'],j_r['hip_pitch'],j_r['knee'],j_r['ankle'])
 74 |         time.sleep(DT)
 75 | 
 76 |     print(f"Walking {N_STEPS} steps...")
 77 |     Nss=int(STEP_DURATION/DT); Nds=int(DS_DURATION/DT)
 78 |     step_starts=[]
 79 |     idx=0
 80 |     for _ in range(N_STEPS):
 81 |         idx+=Nds; step_starts.append(idx); idx+=Nss
 82 | 
 83 |     step_ptr=0; swing_traj=None; swing_time=0.0; swing_side=None
 84 |     stance_x={'left':0.0,'right':0.0}
 85 |     swing_x={'left':0.0,'right':0.0}
 86 | 
 87 |     for k in range(total):
 88 |         loop_start=time.time()
 89 |         com_x=lipm_x.step(zmp_x_pad[k:k+PREVIEW_HORIZON])
 90 |         com_y=lipm_y.step(zmp_y_pad[k:k+PREVIEW_HORIZON])
 91 | 
 92 |         if step_ptr < len(step_starts) and k >= step_starts[step_ptr]:
 93 |             fs=footsteps[step_ptr]
 94 |             swing_side=fs[2]
 95 |             swing_traj=SwingFootTrajectory(
 96 |                 swing_x[swing_side], fs[0], fs[1], STEP_DURATION, SWING_HEIGHT)
 97 |             swing_time=0.0; step_ptr+=1
 98 | 
 99 |         now=time.time()
100 |         with _lock: p=pitch
101 |         dt_b=max(now-last_t, DT); last_t=now
102 |         bal_int=np.clip(bal_int+p*dt_b, -0.3, 0.3)
103 |         bal_d=(p-bal_last)/dt_b; bal_last=p
104 |         bal=np.clip(Kp_bal*p+Ki_bal*bal_int+Kd_bal*bal_d, -0.25, 0.25)
105 | 
106 |         hr_l=-com_y*2.0+(-bal*0.3)
107 |         hr_r= com_y*2.0+( bal*0.3)
108 | 
109 |         if swing_traj and swing_side:
110 |             sx,sy,sz=swing_traj.at(swing_time)
111 |             swing_time+=DT
112 |             if swing_side=='left':
113 |                 j_l=ik_l.solve(COM_HEIGHT, sx-com_x, sz, hr_l)
114 |                 j_r=ik_r.solve(COM_HEIGHT, stance_x['right']-com_x, 0.0, hr_r)
115 |                 swing_x['left']=sx
116 |             else:
117 |                 j_r=ik_r.solve(COM_HEIGHT, sx-com_x, sz, hr_r)
118 |                 j_l=ik_l.solve(COM_HEIGHT, stance_x['left']-com_x, 0.0, hr_l)
119 |                 swing_x['right']=sx
120 |         else:
121 |             j_l=ik_l.solve(COM_HEIGHT, stance_x['left']-com_x, 0.0, hr_l)
122 |             j_r=ik_r.solve(COM_HEIGHT, stance_x['right']-com_x, 0.0, hr_r)
123 | 
124 |         send_all(j_l['hip_roll'],j_l['hip_pitch'],j_l['knee'],j_l['ankle'],
125 |                  j_r['hip_roll'],j_r['hip_pitch'],j_r['knee'],j_r['ankle'])
126 | 
127 |         if k%25==0:
128 |             print(f"\rk={k}/{total} com_x={com_x:+.3f} com_y={com_y:+.3f} "
129 |                   f"pitch={math.degrees(p):+.1f}deg bal={bal:+.3f} "
130 |                   f"step={step_ptr}/{N_STEPS}", end='', flush=True)
131 | 
132 |         elapsed=time.time()-loop_start
133 |         if elapsed < DT: time.sleep(DT-elapsed)
134 | 
135 |     print("\nDone. Returning to stand...")
136 |     j_l=ik_l.solve(COM_HEIGHT,0.0,0.0)
137 |     j_r=ik_r.solve(COM_HEIGHT,0.0,0.0)
138 |     for _ in range(50):
139 |         send_all(j_l['hip_roll'],j_l['hip_pitch'],j_l['knee'],j_l['ankle'],
140 |                  j_r['hip_roll'],j_r['hip_pitch'],j_r['knee'],j_r['ankle'])
141 |         time.sleep(DT)
142 | 
143 | if __name__=='__main__':
144 |     main()
