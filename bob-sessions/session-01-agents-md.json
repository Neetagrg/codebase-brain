212 | 
213 |     if abs(world_com[0]) > 0.005:
214 |         print(f"  ⚠️  FORE-AFT CoM (X) = {world_com[0]:.4f} m — consider shifting mass.")
215 |     else:
216 |         print(f"  ✅ Fore-aft balance OK  (|X| = {abs(world_com[0]):.5f} m < 0.005 m)")
217 | 
218 |     # Sanity-check CoM height: for a bipedal robot the CoM should be above mid-stance
219 |     print(f"\n  CoM height (Z) = {world_com[2]:.4f} m above base_link origin.")
220 |     print(f"{'─'*62}\n")
221 | 
222 |     return total_mass, world_com
223 | 
