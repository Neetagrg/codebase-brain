 3 | class SwingFootTrajectory:
 4 |     def __init__(self, start_x, end_x, foot_y, duration=0.6, max_height=0.04):
 5 |         self.x0 = start_x
 6 |         self.x1 = end_x
 7 |         self.y  = foot_y
 8 |         self.T  = duration
 9 |         self.h  = max_height
10 | 
11 |     def at(self, t):
12 |         t = np.clip(t, 0.0, self.T)
13 |         phase = t / self.T
14 |         x = self.x0 + (self.x1 - self.x0) * phase
15 |         z = self.h * np.sin(np.pi * phase)
16 |         return x, self.y, z
17 | 
18 |     def is_done(self, t):
19 |         return t >= self.T
20 | 
21 | 
22 | class FootstepPlanner:
23 |     def __init__(self, step_length=0.06, foot_separation=0.08, n_steps=6):
24 |         self.sl = step_length
25 |         self.fs = foot_separation
26 |         self.n  = n_steps
27 | 
28 |     def plan(self):
29 |         footsteps = []
30 |         x = 0.0
31 |         for i in range(self.n):
32 |             x += self.sl
33 |             side = 'left' if i % 2 == 0 else 'right'
34 |             y = self.fs/2 if side == 'left' else -self.fs/2
35 |             footsteps.append((x, y, side))
36 |         return footsteps
