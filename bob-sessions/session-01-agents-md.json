  1 | import numpy as np
  2 | from scipy.linalg import solve_discrete_are
  3 | 
  4 | class LIPMPreviewController:
  5 |     def __init__(self, dt=0.02, com_height=0.35, preview_horizon=20):
  6 |         self.dt = dt
  7 |         self.g  = 9.81
  8 |         self.zc = com_height
  9 |         self.N  = preview_horizon
 10 | 
 11 |         Ac = np.array([[0,1,0],[0,0,1],[0,0,0]])
 12 |         Bc = np.array([[0],[0],[1]])
 13 |         Cc = np.array([[1, 0, -self.zc/self.g]])
 14 | 
 15 |         self.A = np.eye(3) + dt * Ac
 16 |         self.B = dt * Bc
 17 |         self.C = Cc
 18 | 
 19 |         Qe = 1.0
 20 |         R  = 1e-6
 21 | 
 22 |         A_aug = np.zeros((4,4))
 23 |         A_aug[0,0] = 1.0
 24 |         A_aug[0,1:4] = (self.C @ self.A).flatten()
 25 |         A_aug[1:4,1:4] = self.A
 26 | 
 27 |         B_aug = np.zeros((4,1))
 28 |         B_aug[0,0] = float(np.squeeze(self.C @ self.B))
 29 |         B_aug[1:4,0] = self.B.flatten()
 30 | 
 31 |         Q_aug = np.zeros((4,4))
 32 |         Q_aug[0,0] = Qe
 33 | 
 34 |         P = solve_discrete_are(A_aug, B_aug, Q_aug, np.array([[R]]))
 35 |         K = np.linalg.inv(R + B_aug.T @ P @ B_aug) @ B_aug.T @ P @ A_aug
 36 |         self.Ke = float(K[0,0])
 37 |         self.Kx = K[0,1:4].flatten()
 38 | 
 39 |         Acl = A_aug - B_aug @ K
 40 |         self.Gp = np.zeros(self.N)
 41 |         tmp = np.linalg.inv(R + B_aug.T @ P @ B_aug) @ B_aug.T
 42 |         vec = np.zeros((4,1))
 43 |         vec[0,0] = float(np.squeeze(self.C @ self.B))
 44 |         vec[1:4,0] = self.B.flatten()
 45 |         power = np.eye(4)
 46 |         for i in range(self.N):
 47 |             self.Gp[i] = float(np.squeeze(tmp @ power @ P @ vec))
 48 |             power = power @ Acl
 49 | 
 50 |         self.x = np.zeros(3)
 51 |         self.e = 0.0
 52 | 
 53 |     def reset(self, com_pos=0.0):
 54 |         self.x = np.array([com_pos, 0.0, 0.0])
 55 |         self.e = 0.0
 56 | 
 57 |     def step(self, zmp_ref_preview):
 58 |         zmp_now = float(np.squeeze(self.C @ self.x))
 59 |         self.e += zmp_now - float(zmp_ref_preview[0])
 60 |         preview_sum = sum(self.Gp[i]*zmp_ref_preview[i] for i in range(self.N))
 61 |         u = -self.Ke*self.e - float(np.squeeze(self.Kx @ self.x)) - preview_sum
 62 |         self.x = self.A @ self.x + self.B.flatten() * float(u)
 63 |         return float(np.squeeze(self.x[0]))
 64 | 
 65 |     @property
 66 |     def com_pos(self): return float(self.x[0])
 67 |     @property
 68 |     def com_vel(self): return float(self.x[1])
 69 |     @property
 70 |     def zmp(self): return float(np.squeeze(self.C @ self.x))
 71 | 
 72 | 
 73 | class ZMPReferenceGenerator:
 74 |     def __init__(self, dt=0.02, step_duration=0.6, ds_duration=0.1,
 75 |                  step_length=0.06, foot_separation=0.08):
 76 |         self.dt  = dt
 77 |         self.Tss = step_duration
 78 |         self.Tds = ds_duration
 79 |         self.sl  = step_length
 80 |         self.fs  = foot_separation
 81 |         self.Nss = int(self.Tss / dt)
 82 |         self.Nds = int(self.Tds / dt)
 83 | 
 84 |     def generate(self, n_steps=6):
 85 |         zmp_x, zmp_y = [], []
 86 |         foot_x, foot_y = 0.0, self.fs/2
 87 |         for step_idx in range(n_steps):
 88 |             side = 1 if step_idx % 2 == 0 else -1
 89 |             foot_x += self.sl
 90 |             foot_y  = side * self.fs/2
 91 |             prev_x = zmp_x[-1] if zmp_x else 0.0
 92 |             prev_y = zmp_y[-1] if zmp_y else 0.0
 93 |             for k in range(self.Nds):
 94 |                 t = k / max(self.Nds-1, 1)
 95 |                 zmp_x.append(prev_x + t*(foot_x - prev_x))
 96 |                 zmp_y.append(prev_y + t*(foot_y - prev_y))
 97 |             for _ in range(self.Nss):
 98 |                 zmp_x.append(foot_x)
 99 |                 zmp_y.append(foot_y)
100 |         return np.array(zmp_x), np.array(zmp_y)
