<content lines="1-55">
 1 | #!/usr/bin/env python3
 2 | """
 3 | Balance controller for ArduBiped_Proto - stronger PID with ankle correction
 4 | """
 5 | from pymavlink import mavutil
 6 | import time, math, subprocess
 7 | 
 8 | print("Connecting to ArduPilot on udp:14551...")
 9 | mav = mavutil.mavlink_connection('udp:0.0.0.0:14551')
10 | mav.wait_heartbeat()
11 | print("Connected!")
12 | 
13 | # Stronger gains
14 | Kp, Ki, Kd = 2.0, 0.01, 0.5
15 | integral, last_error, last_time = 0, 0, time.time()
16 | 
17 | # Standing pose offsets
18 | HIP_STAND   = -0.09
19 | KNEE_STAND  =  0.35
20 | ANKLE_STAND =  0.0
21 | 
22 | def send_joint(topic, angle):
23 |     subprocess.Popen(
24 |         ['gz','topic','-t',topic,'-m','gz.msgs.Double','-p',f'data: {angle:.4f}'],
25 |         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
26 | 
27 | print("Balance controller running...")
28 | while True:
29 |     msg = mav.recv_match(type='ATTITUDE', blocking=True, timeout=1.0)
30 |     if msg:
31 |         pitch = msg.pitch
32 |         now = time.time()
33 |         dt = max(now - last_time, 0.01)
34 |         error = pitch
35 |         integral = max(-0.5, min(0.5, integral + error * dt))
36 |         derivative = (error - last_error) / dt
37 |         correction = max(-0.4, min(0.4,
38 |             Kp*error + Ki*integral + Kd*derivative))
39 | 
40 |         # Hip correction (primary)
41 |         hip = HIP_STAND - correction
42 |         # Ankle correction (opposite direction, smaller)
43 |         ankle = ANKLE_STAND + correction * 0.5
44 | 
45 |         send_joint('/l_hip_pitch/cmd', hip)
46 |         send_joint('/r_hip_pitch/cmd', hip)
47 |         send_joint('/l_ankle/cmd', ankle)
48 |         send_joint('/r_ankle/cmd', ankle)
49 |         send_joint('/l_knee/cmd', KNEE_STAND)
50 |         send_joint('/r_knee/cmd', KNEE_STAND)
51 | 
52 |         last_error, last_time = error, now
53 |         print(f"Pitch:{math.degrees(pitch):+.1f}° Corr:{correction:+.4f} "
54 |               f"Hip:{hip:+.3f} Ankle:{ankle:+.3f}")
55 |     time.sleep(0.02)
</content>
