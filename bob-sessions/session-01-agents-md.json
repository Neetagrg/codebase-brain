 1 | import xml.etree.ElementTree as ET
 2 | import os
 3 | 
 4 | def print_urdf_tree(file_path):
 5 |     tree = ET.parse(file_path)
 6 |     root = tree.getroot()
 7 | 
 8 |     joints = root.findall('joint')
 9 | 
10 |     print("\n--- Kinematic Tree: " + os.path.basename(file_path) + " ---")
11 | 
12 |     # adj maps parent_link_name -> list of (child_link_name, joint_name, joint_type)
13 |     adj = {}
14 |     for joint in joints:
15 |         parent = joint.find('parent').get('link')
16 |         child  = joint.find('child').get('link')
17 |         name   = joint.get('name')
18 |         jtype  = joint.get('type')
19 |         adj.setdefault(parent, []).append((child, name, jtype))
20 | 
21 |     def walk(link_name, prefix="", is_last=True):
22 |         connector = "+-- " if is_last else "+-- "
23 |         print(prefix + connector + link_name)
24 | 
25 |         children = adj.get(link_name, [])
26 |         child_prefix = prefix + ("    " if is_last else "|   ")
27 | 
28 |         for i, (child_link, joint_name, joint_type) in enumerate(children):
29 |             last = (i == len(children) - 1)
30 |             joint_connector = "+-- " if last else "+-- "
31 |             print(child_prefix + joint_connector + "[" + joint_name + "] (" + joint_type + ")")
32 |             walk(child_link, child_prefix + ("    " if last else "|   "), is_last=last)
33 | 
34 |     walk("base_link")
35 | 
36 | if __name__ == "__main__":
37 |     script_dir = os.path.dirname(os.path.abspath(__file__))
38 |     urdf_path  = os.path.join(script_dir, '..', 'humanoid_proto.urdf')
39 |     print_urdf_tree(urdf_path)
