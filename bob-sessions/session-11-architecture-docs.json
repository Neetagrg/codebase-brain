  1 | #!/usr/bin/env python3
  2 | """
  3 | AGENTS.md Validation Tool
  4 | 
  5 | Validates that bob-copilot/AGENTS.md stays accurate by checking:
  6 | 1. File coverage - all mentioned files exist
  7 | 2. Line references - line numbers are still valid
  8 | 3. Drift detection - staleness vs actual files
  9 | 4. Quality metrics - documentation completeness
 10 | 
 11 | Exit codes:
 12 |   0 - All checks pass, drift < 15%
 13 |   1 - Validation failures or drift >= 15%
 14 | """
 15 | 
 16 | import argparse
 17 | import json
 18 | import re
 19 | import sys
 20 | from dataclasses import dataclass, asdict
 21 | from datetime import datetime
 22 | from pathlib import Path
 23 | from typing import Any, Dict, List, Set, Tuple, Optional
 24 | 
 25 | 
 26 | @dataclass
 27 | class ValidationResult:
 28 |     """Results from validation checks"""
 29 |     total_files_mentioned: int
 30 |     files_exist: int
 31 |     files_missing: List[str]
 32 |     coverage_percentage: float
 33 |     
 34 |     total_line_refs: int
 35 |     valid_line_refs: int
 36 |     stale_line_refs: List[Dict[str, Any]]
 37 |     line_accuracy_percentage: float
 38 |     
 39 |     agents_md_modified: str
 40 |     newest_repo_file_modified: str
 41 |     staleness_percentage: float
 42 |     
 43 |     total_gotchas: int
 44 |     total_failure_modes: int
 45 |     quality_score: float
 46 |     
 47 |     drift_check_passed: bool
 48 |     overall_passed: bool
 49 | 
 50 | 
 51 | class AgentsValidator:
 52 |     """Validates AGENTS.md against actual codebase"""
 53 |     
 54 |     def __init__(self, workspace_dir: Path, verbose: bool = False):
 55 |         self.workspace_dir = workspace_dir
 56 |         self.agents_md_path = workspace_dir / "bob-copilot" / "AGENTS.md"
 57 |         self.verbose = verbose
 58 |         
 59 |         if not self.agents_md_path.exists():
 60 |             raise FileNotFoundError(f"AGENTS.md not found at {self.agents_md_path}")
 61 |         
 62 |         self.agents_content = self.agents_md_path.read_text()
 63 |         self.agents_lines = self.agents_content.split('\n')
 64 |     
 65 |     def log(self, message: str) -> None:
 66 |         """Print message if verbose mode enabled"""
 67 |         if self.verbose:
 68 |             print(f"[DEBUG] {message}")
 69 |     
 70 |     def extract_file_paths(self) -> Set[str]:
 71 |         """Extract all file paths mentioned in AGENTS.md"""
 72 |         file_paths = set()
 73 |         
 74 |         # Pattern 1: Markdown headers with file paths (e.g., #### `model.sdf`)
 75 |         header_pattern = r'####?\s+`([^`]+\.[a-zA-Z0-9]+)`'
 76 |         
 77 |         # Pattern 2: Inline code with file paths (e.g., `scripts/gait_controller.py`)
 78 |         inline_pattern = r'`([a-zA-Z0-9_/-]+\.[a-zA-Z0-9]+)`'
 79 |         
 80 |         for match in re.finditer(header_pattern, self.agents_content):
 81 |             file_paths.add(match.group(1))
 82 |         
 83 |         for match in re.finditer(inline_pattern, self.agents_content):
 84 |             path = match.group(1)
 85 |             # Filter out likely file paths (has directory separator or common extensions)
 86 |             if '/' in path or path.endswith(('.py', '.sh', '.sdf', '.param', '.parm', '.config', '.md', '.DAT')):
 87 |                 file_paths.add(path)
 88 |         
 89 |         self.log(f"Extracted {len(file_paths)} file paths from AGENTS.md")
 90 |         return file_paths
 91 |     
 92 |     def check_file_coverage(self) -> Tuple[int, int, List[str]]:
 93 |         """Check which mentioned files actually exist"""
 94 |         file_paths = self.extract_file_paths()
 95 |         files_exist = 0
 96 |         files_missing = []
 97 |         
 98 |         for file_path in sorted(file_paths):
 99 |             # Try multiple possible locations
100 |             possible_paths = [
101 |                 self.workspace_dir / file_path,
102 |                 self.workspace_dir / file_path.lstrip('/'),
103 |             ]
104 |             
105 |             exists = any(p.exists() for p in possible_paths)
106 |             
107 |             if exists:
108 |                 files_exist += 1
109 |                 self.log(f"✓ Found: {file_path}")
110 |             else:
111 |                 files_missing.append(file_path)
112 |                 self.log(f"✗ Missing: {file_path}")
113 |         
114 |         return len(file_paths), files_exist, files_missing
115 |     
116 |     def extract_line_references(self) -> List[Dict[str, Any]]:
117 |         """Extract all line number references from AGENTS.md"""
118 |         line_refs = []
119 |         
120 |         # Pattern: "line 123", "lines 45-67", "(line 89)", etc.
121 |         patterns = [
122 |             r'line\s+(\d+)',
123 |             r'lines\s+(\d+)-(\d+)',
124 |             r'\(line\s+(\d+)\)',
125 |             r'line\s+(\d+),\s+(\d+)',
126 |         ]
127 |         
128 |         for line_num, line in enumerate(self.agents_lines, 1):
129 |             for pattern in patterns:
130 |                 for match in re.finditer(pattern, line, re.IGNORECASE):
131 |                     # Extract all numbers from the match
132 |                     numbers = [int(g) for g in match.groups() if g]
133 |                     
134 |                     # Try to find associated file in nearby context
135 |                     context_start = max(0, line_num - 5)
136 |                     context_end = min(len(self.agents_lines), line_num + 2)
137 |                     context = '\n'.join(self.agents_lines[context_start:context_end])
138 |                     
139 |                     # Look for file references in context
140 |                     file_match = re.search(r'`([a-zA-Z0-9_/-]+\.[a-zA-Z0-9]+)`', context)
141 |                     file_path = file_match.group(1) if file_match else None
142 |                     
143 |                     for num in numbers:
144 |                         line_refs.append({
145 |                             'agents_line': line_num,
146 |                             'referenced_line': num,
147 |                             'file': file_path,
148 |                             'context': line.strip()
149 |                         })
150 |         
151 |         self.log(f"Found {len(line_refs)} line references")
152 |         return line_refs
153 |     
154 |     def validate_line_references(self, line_refs: List[Dict[str, Any]]) -> Tuple[int, List[Dict[str, Any]]]:
155 |         """Validate that referenced line numbers still exist in files"""
156 |         valid_refs = 0
157 |         stale_refs = []
158 |         
159 |         for ref in line_refs:
160 |             if not ref['file']:
161 |                 continue  # Skip if we couldn't determine the file
162 |             
163 |             file_path = self.workspace_dir / ref['file'].lstrip('/')
164 |             
165 |             if not file_path.exists():
166 |                 stale_refs.append({**ref, 'reason': 'file_not_found'})
167 |                 continue
168 |             
169 |             try:
170 |                 with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
171 |                     lines = f.readlines()
172 |                 
173 |                 if ref['referenced_line'] <= len(lines):
174 |                     valid_refs += 1
175 |                     self.log(f"✓ Valid line ref: {ref['file']}:{ref['referenced_line']}")
176 |                 else:
177 |                     stale_refs.append({**ref, 'reason': 'line_out_of_range', 'actual_lines': len(lines)})
178 |                     self.log(f"✗ Stale line ref: {ref['file']}:{ref['referenced_line']} (file has {len(lines)} lines)")
179 |             except Exception as e:
180 |                 stale_refs.append({**ref, 'reason': f'read_error: {str(e)}'})
181 |         
182 |         return valid_refs, stale_refs
183 |     
184 |     def calculate_drift(self) -> Tuple[datetime, datetime, float]:
185 |         """Calculate staleness percentage based on file modification times"""
186 |         agents_mtime = datetime.fromtimestamp(self.agents_md_path.stat().st_mtime)
187 |         
188 |         # Find newest file in the repo (excluding AGENTS.md itself)
189 |         newest_mtime = agents_mtime
190 |         newest_file = None
191 |         
192 |         for file_path in self.workspace_dir.rglob('*'):
193 |             if file_path.is_file() and file_path != self.agents_md_path:
194 |                 # Skip hidden files and common non-source files
195 |                 if any(part.startswith('.') for part in file_path.parts):
196 |                     continue
197 |                 if file_path.suffix in ['.pyc', '.log', '.tmp']:
198 |                     continue
199 |                 
200 |                 try:
201 |                     mtime = datetime.fromtimestamp(file_path.stat().st_mtime)
202 |                     if mtime > newest_mtime:
203 |                         newest_mtime = mtime
204 |                         newest_file = file_path
205 |                 except:
206 |                     continue
207 |         
208 |         # Calculate staleness as percentage of time difference
209 |         if newest_mtime > agents_mtime:
210 |             time_diff = (newest_mtime - agents_mtime).total_seconds()
211 |             # Normalize to percentage (1 day = 10% staleness, capped at 100%)
212 |             staleness = min(100.0, (time_diff / 86400) * 10)
213 |         else:
214 |             staleness = 0.0
215 |         
216 |         self.log(f"AGENTS.md modified: {agents_mtime}")
217 |         self.log(f"Newest repo file: {newest_file} at {newest_mtime}")
218 |         self.log(f"Staleness: {staleness:.1f}%")
219 |         
220 |         return agents_mtime, newest_mtime, staleness
221 |     
222 |     def count_quality_metrics(self) -> Tuple[int, int]:
223 |         """Count gotchas and failure modes documented"""
224 |         gotchas = len(re.findall(r'\*\*GOTCHA\*\*', self.agents_content, re.IGNORECASE))
225 |         
226 |         # Count failure modes section entries
227 |         failure_section = re.search(
228 |             r'## ⚠️ Known Failure Modes(.*?)(?=##|\Z)',
229 |             self.agents_content,
230 |             re.DOTALL
231 |         )
232 |         
233 |         if failure_section:
234 |             failure_content = failure_section.group(1)
235 |             # Count numbered failure modes (### 1., ### 2., etc.)
236 |             failure_modes = len(re.findall(r'###\s+\d+\.', failure_content))
237 |         else:
238 |             failure_modes = 0
239 |         
240 |         self.log(f"Found {gotchas} gotchas and {failure_modes} failure modes")
241 |         return gotchas, failure_modes
242 |     
243 |     def calculate_quality_score(self, files_exist: int, total_files: int, 
244 |                                 gotchas: int, failure_modes: int) -> float:
245 |         """Calculate overall quality score (0-100)"""
246 |         # Weighted scoring:
247 |         # - 40% file coverage
248 |         # - 30% gotchas (1 point per gotcha, max 30)
249 |         # - 30% failure modes (3 points per mode, max 30)
250 |         
251 |         coverage_score = (files_exist / total_files * 40) if total_files > 0 else 0
252 |         gotcha_score = min(30, gotchas)
253 |         failure_score = min(30, failure_modes * 3)
254 |         
255 |         total_score = coverage_score + gotcha_score + failure_score
256 |         return round(total_score, 1)
257 |     
258 |     def validate(self, quiet: bool = False) -> ValidationResult:
259 |         """Run all validation checks"""
260 |         if not quiet:
261 |             print("🔍 Validating AGENTS.md...")
262 |             print()
263 |         
264 |         # 1. File Coverage Check
265 |         if not quiet:
266 |             print("📁 Checking file coverage...")
267 |         total_files, files_exist, files_missing = self.check_file_coverage()
