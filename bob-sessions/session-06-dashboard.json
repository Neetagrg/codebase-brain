        let currentQuestion = 0;
        let isTyping = false;

        // Typewriter effect
        function typeWriter(element, text, speed = 30) {
            return new Promise((resolve) => {
                element.innerHTML = '';
                element.classList.add('typing-cursor');
                let i = 0;
                
                function type() {
                    if (i < text.length) {
                        if (text.charAt(i) === '<') {
                            // Handle HTML tags
                            let tagEnd = text.indexOf('>', i);
                            element.innerHTML += text.substring(i, tagEnd + 1);
                            i = tagEnd + 1;
                        } else {
                            element.innerHTML += text.charAt(i);
                            i++;
                        }
                        setTimeout(type, speed);
                    } else {
                        element.classList.remove('typing-cursor');
                        resolve();
                    }
                }
                type();
            });
        }

        // Animate metrics
        function animateMetrics(metrics) {
            const elements = {
                specificity: document.getElementById('metric-specificity'),
                time: document.getElementById('metric-time'),
                files: document.getElementById('metric-files'),
                confidence: document.getElementById('metric-confidence')
            };

            // Animate specificity
            animateNumber(elements.specificity, 0, metrics.specificity, 1500, (val) => val + '%');
            
            // Animate time improvement
            animateNumber(elements.time, 0, metrics.time, 1500, (val) => val + 'x');
            
            // Animate files
            animateNumber(elements.files, 0, metrics.files, 1500);
            
            // Animate confidence
            animateNumber(elements.confidence, 0, metrics.confidence, 1500, (val) => val + '%');
        }

        function animateNumber(element, start, end, duration, formatter = (val) => val) {
            const startTime = performance.now();
            
            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const current = Math.floor(start + (end - start) * progress);
                
                element.textContent = formatter(current);
                
                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }
            
            requestAnimationFrame(update);
        }

        // Load question
        async function loadQuestion(index) {
            if (isTyping) return;
            
            currentQuestion = index;
            const question = questions[index];
            
            // Update active button
            document.querySelectorAll('.question-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i === index);
            });
            
            // Update questions
            document.getElementById('question-left').textContent = question.question;
            document.getElementById('question-right').textContent = question.question;
            
            // Update left panel (generic)
            document.getElementById('answer-left').innerHTML = question.generic.replace(/\n/g, '<br>').replace(/•/g, '<li>').replace(/\n<li>/g, '</li>\n<li>');
            
            // Update file count
            document.getElementById('file-count').textContent = question.metrics.files;
            
            // Type right panel answer
            isTyping = true;
            const rightAnswer = document.getElementById('answer-right');
            await typeWriter(rightAnswer, question.detailed, 20);
            isTyping = false;
            
            // Animate metrics
            setTimeout(() => {
                animateMetrics(question.metrics);
            }, 500);
        }

        // Copy to clipboard functionality
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                // Show feedback
                const feedback = document.createElement('div');
                feedback.textContent = 'Copied!';
                feedback.className = 'fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg z-50';
                document.body.appendChild(feedback);
                setTimeout(() => feedback.remove(), 2000);
            });
        }

        // Add click handlers for code blocks
        document.addEventListener('click', (e) => {
            if (e.target.closest('.code-block')) {
                const codeBlock = e.target.closest('.code-block');
                copyToClipboard(codeBlock.textContent);
            }
        });

        // Initialize with first question
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                loadQuestion(0);
            }, 1000);
        });

        // Add smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html></content>
