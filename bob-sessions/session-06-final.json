name: Codebase Brain Workflow CI

on:
  push:
    branches: [ main, master, develop ]
  pull_request:
    branches: [ main, master, develop ]
  workflow_dispatch:

jobs:
  test-workflow:
    name: Validate Workflow System
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'
        
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install pytest pytest-cov
        
    - name: Run workflow validation tests
      run: |
        pytest tests/test_workflow.py -v --tb=short
        
    - name: Generate test report
      if: always()
      run: |
        pytest tests/test_workflow.py -v --tb=short --junit-xml=test-results.xml
        
    - name: Upload test results
      if: always()
      uses: actions/upload-artifact@v4
      with:
        name: test-results
        path: test-results.xml
        
    - name: Validate AGENTS.md structure
      run: |
        echo "Checking AGENTS.md line count..."
        line_count=$(wc -l < AGENTS.md)
        echo "AGENTS.md has $line_count lines"
        if [ $line_count -lt 200 ]; then
          echo "ERROR: AGENTS.md has fewer than 200 lines"
          exit 1
        fi
        echo "✓ AGENTS.md line count validation passed"
        
    - name: Validate slash commands
      run: |
        echo "Checking slash command files..."
        for cmd in debug-joint gait-plan lua-trace sdf-check; do
          file="bob-copilot/commands/${cmd}.md"
          if [ ! -f "$file" ]; then
            echo "ERROR: Missing slash command file: $file"
            exit 1
          fi
          size=$(wc -c < "$file")
          if [ $size -lt 50 ]; then
            echo "ERROR: Slash command file too small: $file ($size bytes)"
            exit 1
          fi
          echo "✓ $file validated"
        done
        echo "✓ All slash command files validated"
        
    - name: Validate domain skill
      run: |
        echo "Checking domain skill file..."
        skill_file="bob-copilot/skills/arduhumanoid-expert.md"
        if [ ! -f "$skill_file" ]; then
          echo "ERROR: Missing domain skill file: $skill_file"
          exit 1
        fi
        line_count=$(wc -l < "$skill_file")
        echo "Domain skill file has $line_count lines"
        if [ $line_count -lt 400 ]; then
          echo "ERROR: Domain skill file has fewer than 400 lines"
          exit 1
        fi
        echo "✓ Domain skill file validated"
        
    - name: Validate documentation
      run: |
        echo "Checking documentation files..."
        for doc in problem-statement bob-usage-statement; do
          file="docs/${doc}.md"
          if [ ! -f "$file" ]; then
            echo "ERROR: Missing documentation file: $file"
            exit 1
          fi
          size=$(wc -c < "$file")
          if [ $size -lt 200 ]; then
            echo "ERROR: Documentation file too small: $file ($size bytes)"
            exit 1
          fi
          echo "✓ $file validated"
        done
        echo "✓ All documentation files validated"
        
    - name: Summary
      if: success()
      run: |
        echo "=========================================="
        echo "✓ Codebase Brain Workflow Validation PASSED"
        echo "=========================================="
        echo ""
        echo "All required components validated:"
        echo "  ✓ AGENTS.md (200+ lines)"
        echo "  ✓ 4 slash command files"
        echo "  ✓ Domain skill file (400+ lines)"
        echo "  ✓ Documentation files"
        echo ""
        echo "Workflow system is properly configured!"
</content>
