            {
                title: "Balance Control",
                content: "PID on pitch: Kp=2.0, Ki=0.01, Kd=0.5 (balance_controller). Kp=0.08, Ki=0.001, Kd=0.01 (gait_controller)",
                category: "Control"
            },
            {
                title: "Robot Falls on Spawn",
                content: "Initial pose doesn't match standing pose, or startup.sh not running. Fix: Ensure world file matches gait controller",
                category: "Failure Mode"
            },
            {
                title: "Robot Explodes",
                content: "Physics timestep too large (>0.004s) or joint limits violated. Keep max_step_size ≤ 0.004s",
                category: "Failure Mode"
            },
            {
                title: "PWM Conversion",
                content: "angle = (pwm - 1500) / 500 * multiplier + offset. Channel mapping: CH0→l_hip_pitch, CH1→r_hip_pitch, CH2→l_knee, CH3→r_knee",
                category: "Configuration"
            },
            {
                title: "Standing Pose",
                content: "HIP_STAND = -0.09 rad, KNEE_STAND = 0.35 rad, ANKLE_STAND = 0.0 rad (fixed joint)",
                category: "Configuration"
            }
        ];

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            
            if (query.length < 2) {
                searchResults.innerHTML = '';
                return;
            }

            const results = searchableContent.filter(item => 
                item.title.toLowerCase().includes(query) || 
                item.content.toLowerCase().includes(query)
            );

            if (results.length === 0) {
                searchResults.innerHTML = '<div class="text-center text-gray-500 py-8">No results found</div>';
                return;
            }

            searchResults.innerHTML = results.map(result => `
                <div class="bg-gray-800 rounded-lg p-6 card-hover">
                    <div class="flex items-start justify-between mb-2">
                        <h3 class="text-lg font-semibold text-purple-400">${result.title}</h3>
                        <span class="text-xs bg-gray-700 px-2 py-1 rounded">${result.category}</span>
                    </div>
                    <p class="text-gray-300 text-sm">${result.content}</p>
                </div>
            `).join('');
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });
    </script>
</body>
</html>
</content>
