575 | ```python
576 | # Ensure topic names match /<joint_name>/cmd pattern
577 | for match in re.finditer(r'<joint_name>([^<]+)</joint_name>\s*<topic>([^<]+)</topic>', sdf_content):
578 |     joint = match.group(1)
579 |     topic = match.group(2)
